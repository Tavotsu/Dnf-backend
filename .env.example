# ============================================
# DNF Backend Environment Variables Configuration
# ============================================
# Copia este archivo como .env en la raíz del proyecto y configura los valores reales

# ============================================
# SECURITY - JWT Secret
# ============================================
# Cambia esto por una cadena larga y segura en producción
JWT_SECRET=EstaEsUnaClaveSecretaMuyLargaParaAsegurarElTokenDeSanosYSalvos2026

# ============================================
# DATABASE Configuration
# ============================================
# URL de conexión a PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres-db:5432/dnf_db
# Username de la base de datos
SPRING_DATASOURCE_USERNAME=admin
# Password de la base de datos
SPRING_DATASOURCE_PASSWORD=adminpassword

# ============================================
# EUREKA Discovery Server
# ============================================
# URL del servidor Eureka para descubrimiento de servicios
EUREKA_DEFAULT_ZONE=http://eureka-server:8761/eureka/

# ============================================
# EMAIL Service Configuration (Ms-notificaciones)
# ============================================
# Host SMTP del servidor de correo
MAIL_HOST=smtp.gmail.com
# Puerto SMTP
MAIL_PORT=587
# Usuario/email para autenticarse en el servidor SMTP
MAIL_USERNAME=tu_usuario@gmail.com
# Contraseña o app password para el servidor SMTP
MAIL_PASSWORD=tu_app_password

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. Para desarrollar localmente con Docker:
#    - Usa "postgres-db" como host de la BD (nombre del servicio)
#    - Usa "eureka-server" como host de Eureka
#
# 2. En producción:
#    - Cambia JWT_SECRET por una cadena aleatoria larga y segura
#    - Usa contraseñas fuertes para la base de datos
#    - Usa URLs absolutas para Eureka y BD
#    - Configura email con credenciales reales
#
# 3. Para pasar estas variables a Docker:
#    docker compose --env-file .env up --build
#
# 4. Para pasar a un servicio individual (local):
#    export JWT_SECRET="tu_secret"
#    export SPRING_DATASOURCE_URL="tu_url"
#    ./mvnw spring-boot:run
